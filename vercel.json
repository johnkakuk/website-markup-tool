{
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build --workspace @website-markup-tool/frontend",
  "outputDirectory": "apps/frontend/dist",
  "rewrites": [
    {
      "source": "/proxy/:path*",
      "destination": "https://YOUR-RAILWAY-PROXY.up.railway.app/proxy/:path*"
    }
  ]
}
